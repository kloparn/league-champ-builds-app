{
  "name": "league-champ-builds-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.7.0"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "npm run test:unit -- --run && npm run test:e2e",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "refresh:builds": "node --experimental-strip-types --env-file-if-exists=.env scripts/refresh-builds.ts",
    "refresh:builds:fast": "node --experimental-strip-types --env-file-if-exists=.env scripts/refresh-builds.ts --fast",
    "refresh:builds:github": "node --experimental-strip-types --env-file-if-exists=.env scripts/refresh-builds.ts --github"
  },
  "overrides": {
    "cookie": "^0.7.2",
    "esbuild": "^0.25.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@sveltejs/adapter-netlify": "^4.4.0",
    "@sveltejs/kit": "^2.15.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/node": "^22.10.5",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "svelte": "^5.16.0",
    "svelte-check": "^4.1.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.19.0"
  }
}
